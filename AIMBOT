--// SETTINGS & DEFAULTS
local Settings = { 
    Names = false, Boxes = false, Health = false, Skeleton = false, Chams = false, 
    LockOn = false, TeamCheck = false, FriendCheck = false, WallCheck = false, 
    FOV = 150, Smoothness = 4, MaxDistance = 1000, 
    MenuKey = "RightControl", LockBind = "V" 
}

--// SAVE/LOAD LOGIC
local function Save() 
    pcall(function() writefile(SaveFile, Http:JSONEncode(Settings)) end)
end

if isfile(SaveFile) then 
    pcall(function()
        local d = Http:JSONDecode(readfile(SaveFile)) 
        for k, v in pairs(d) do Settings[k] = v end 
    end)
end

