        if input.KeyCode ~= Enum.KeyCode.Unknown then
            MenuKey = input.KeyCode; bindBtn.Text = "Menu Key: " .. MenuKey.Name; listening = false
        end
    elseif not gp and input.KeyCode == MenuKey then
        main.Visible = not main.Visible
    end
end)

