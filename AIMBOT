--// AUTO-SAVE SYSTEM
local ConfigFile = "EliteSettings.json"

local function SaveSettings()
    pcall(function()
        local data = {
            ESP = ESP,
            MenuKey = MenuKey.Name,
            LockBind = tostring(LockBind):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
        }
        writefile(ConfigFile, HttpService:JSONEncode(data))
    end)
end

local function LoadSettings()
    if isfile(ConfigFile) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(ConfigFile)) end)
        if success then
            for k, v in pairs(data.ESP) do if ESP[k] ~= nil then ESP[k] = v end end
            pcall(function() MenuKey = Enum.KeyCode[data.MenuKey] end)
            if data.LockBind == "MouseButton2" then
                LockBind = Enum.UserInputType.MouseButton2
            else
                pcall(function() LockBind = Enum.KeyCode[data.LockBind] end)
            end
        end
    end
end

