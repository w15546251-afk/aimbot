local lockToggleBtn -- Global for syncing

--// UI CONSTRUCTORS
local function CreateToggle(txt, key, p)
    local h = Instance.new("Frame", p); h.Size = UDim2.new(1, -5, 0, 35); h.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", h)
    local b = Instance.new("TextButton", h); b.Size = UDim2.new(0, 45, 0, 20); b.Position = UDim2.new(1, -50, 0.5, -10); b.Text = Settings[key] and "ON" or "OFF"; b.BackgroundColor3 = Settings[key] and Color3.fromRGB(0, 255, 120) or Color3.fromRGB(50, 50, 50); b.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", b).CornerRadius = UDim.new(1,0)
    local l = Instance.new("TextLabel", h); l.Text = "  "..txt; l.Size = UDim2.new(0.7,0,1,0); l.BackgroundTransparency = 1; l.TextColor3 = Color3.new(1,1,1); l.TextXAlignment = "Left"; l.Font = "Gotham"
    
    if key == "LockOn" then lockToggleBtn = b end

    b.MouseButton1Click:Connect(function()
        Settings[key] = not Settings[key]
        b.Text = Settings[key] and "ON" or "OFF"
        b.BackgroundColor3 = Settings[key] and Color3.fromRGB(0, 255, 120) or Color3.fromRGB(50, 50, 50)
        Save()
    end)
end

local function CreateSlider(txt, min, max, key, p)
    local h = Instance.new("Frame", p); h.Size = UDim2.new(1, -5, 0, 50); h.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", h)
    local l = Instance.new("TextLabel", h); l.Text = "  "..txt..": "..Settings[key]; l.Size = UDim2.new(1,0,0,25); l.BackgroundTransparency = 1; l.TextColor3 = Color3.new(1,1,1); l.TextXAlignment = "Left"; l.Font = "Gotham"
    local s = Instance.new("Frame", h); s.Size = UDim2.new(0.9, 0, 0, 4); s.Position = UDim2.new(0.05, 0, 0.7, 0); s.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    local f = Instance.new("Frame", s); f.Size = UDim2.new((Settings[key]-min)/(max-min), 0, 1, 0); f.BackgroundColor3 = Color3.fromRGB(0, 255, 120)
    s.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then local c; c = RunService.RenderStepped:Connect(function() local r = math.clamp((UIS:GetMouseLocation().X - s.AbsolutePosition.X)/s.AbsoluteSize.X, 0, 1) local v = math.floor(min + (r*(max-min))); Settings[key] = v; l.Text = "  "..txt..": "..v; f.Size = UDim2.new(r, 0, 1, 0) if not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then c:Disconnect(); Save() end end) end end)
end

local function CreateBind(txt, current, callback, p) 
    local h = Instance.new("Frame", p); h.Size = UDim2.new(1, -5, 0, 35); h.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", h)
    local b = Instance.new("TextButton", h); b.Size = UDim2.new(0, 80, 0, 25); b.Position = UDim2.new(1, -85, 0.5, -12); b.Text = tostring(current); b.BackgroundColor3 = Color3.fromRGB(30, 30, 30); b.TextColor3 = Color3.new(1, 1, 1); Instance.new("UICorner", b)
    local l = Instance.new("TextLabel", h); l.Text = "  "..txt; l.Size = UDim2.new(0.6,0,1,0); l.BackgroundTransparency = 1; l.TextColor3 = Color3.new(1,1,1); l.TextXAlignment = "Left"; l.Font = "Gotham"
    local listening = false 
    b.MouseButton1Click:Connect(function() listening = true; b.Text = "..." end) 
    UIS.InputBegan:Connect(function(i) 
        if listening and (i.UserInputType == Enum.UserInputType.Keyboard or i.UserInputType == Enum.UserInputType.MouseButton2) then 
            local k = i.KeyCode ~= Enum.KeyCode.Unknown and i.KeyCode.Name or i.UserInputType.Name
            listening = false; b.Text = k; callback(k); Save() 
        end 
    end) 
end

