--// UI HELPERS
local function CreateToggle(name, key, parent)
    local holder = Instance.new("Frame", parent)
    holder.Size = UDim2.new(1, -10, 0, 35)
    holder.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    Instance.new("UICorner", holder)

    local btn = Instance.new("TextButton", holder)
    btn.Size = UDim2.new(0, 45, 0, 20)
    btn.Position = UDim2.new(1, -50, 0.5, -10)
    btn.Text = ESP[key] and "ON" or "OFF"
    btn.BackgroundColor3 = ESP[key] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(45, 45, 50)
    btn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)
    
    if key == "LockOn" then lockToggleBtn = btn end

    local lbl = Instance.new("TextLabel", holder)
    lbl.Text = "  " .. name
    lbl.Size = UDim2.new(0.7, 0, 1, 0)
    lbl.TextColor3 = Color3.new(1, 1, 1)
    lbl.BackgroundTransparency = 1
    lbl.TextXAlignment = "Left"
    lbl.Font = "Gotham"

    btn.MouseButton1Click:Connect(function()
        ESP[key] = not ESP[key]
        btn.Text = ESP[key] and "ON" or "OFF"
        btn.BackgroundColor3 = ESP[key] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(45, 45, 50)
        SaveSettings()
    end)
end

local function CreateSlider(name, min, max, key, parent)
    local holder = Instance.new("Frame", parent)
    holder.Size = UDim2.new(1, -10, 0, 50)
    holder.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    Instance.new("UICorner", holder)

    local label = Instance.new("TextLabel", holder)
    label.Text = "  " .. name .. ": " .. ESP[key]
    label.Size = UDim2.new(1, 0, 0, 25)
    label.TextColor3 = Color3.new(1, 1, 1)
    label.BackgroundTransparency = 1
    label.TextXAlignment = "Left"

    local sliderBg = Instance.new("Frame", holder)
    sliderBg.Size = UDim2.new(0.9, 0, 0, 4)
    sliderBg.Position = UDim2.new(0.05, 0, 0.7, 0)
    sliderBg.BackgroundColor3 = Color3.fromRGB(40, 40, 45)

    local sliderFill = Instance.new("Frame", sliderBg)
    sliderFill.Size = UDim2.new((ESP[key] - min) / (max - min), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(0, 200, 100)

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local con
            con = RunService.RenderStepped:Connect(function()
                local rel = math.clamp((UIS:GetMouseLocation().X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
                local val = math.floor(min + (rel * (max - min)))
                ESP[key] = val
                label.Text = "  " .. name .. ": " .. val
                sliderFill.Size = UDim2.new(rel, 0, 1, 0)
                if not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then 
                    con:Disconnect() 
                    SaveSettings()
                end
            end)
        end
    end)
end

local function CreateBind(name, currentKey, callback, parent)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -10, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    btn.Text = name .. ": " .. (tostring(currentKey):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", ""))
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = "GothamBold"
    Instance.new("UICorner", btn)
    
    local listening = false
    btn.MouseButton1Click:Connect(function()
        listening = true
        btn.Text = "..."
    end)
    
    UIS.InputBegan:Connect(function(input)
        if listening and (input.UserInputType == Enum.UserInputType.Keyboard or input.UserInputType == Enum.UserInputType.MouseButton2) then
            local key = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
            listening = false
            btn.Text = name .. ": " .. (tostring(key):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", ""))
            callback(key)
            SaveSettings()
        end
    end)
end

