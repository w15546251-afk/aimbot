--// WALL CHECK LOGIC
local function IsVisible(targetPart)
    if not ESP.WallCheck then return true end
    local char = LocalPlayer.Character
    if not char then return false end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {char, Camera}
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin).Unit * (targetPart.Position - origin).Magnitude
    local result = workspace:Raycast(origin, direction, params)
    if result then return result.Instance:IsDescendantOf(targetPart.Parent) end
    return true
end

--// DRAWING UTILS
local fovCircle = Drawing.new("Circle")
fovCircle.Thickness = 1; fovCircle.Color = Color3.new(1, 1, 1); fovCircle.Transparency = 0.5

local SkeletonParts = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},{"UpperTorso","LeftUpperArm"},
    {"LeftUpperArm","LeftLowerArm"},{"LeftUpperArm","LeftHand"},{"UpperTorso","RightUpperArm"},
    {"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},{"LowerTorso","LeftUpperLeg"},
    {"LeftUpperLeg","LeftLowerLeg"},{"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"}
}

local Drawings = {}
local function GetDrawings(player)
    if Drawings[player] then return Drawings[player] end
    local d = {
        Box = Drawing.new("Square"), Name = Drawing.new("Text"),
        HealthOutline = Drawing.new("Square"), HealthBar = Drawing.new("Square"),
        Skeleton = {}
    }
    -- Force White ESP Colors
    d.Box.Thickness = 1; d.Box.Color = Color3.new(1, 1, 1)
    d.Name.Center = true; d.Name.Outline = true; d.Name.Size = 13; d.Name.Color = Color3.new(1, 1, 1)
    d.HealthBar.Filled = true; d.HealthOutline.Filled = true
    for i=1,#SkeletonParts do
        local l = Drawing.new("Line"); l.Thickness = 1; l.Color = Color3.new(1, 1, 1); table.insert(d.Skeleton, l)
    end
    Drawings[player] = d
    return d
end

--// MAIN LOOP
RunService:BindToRenderStep("SystemSync_V18", 201, function(dt)
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    fovCircle.Visible = ESP.LockOn; fovCircle.Radius = ESP.FOV; fovCircle.Position = screenCenter

    local targetPart = nil
    local closestDist = ESP.FOV

    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local d = GetDrawings(p)
        local char = p.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local head = char and char:FindFirstChild("Head")

        if char and root and hum and hum.Health > 0 then
            local distFromPlayer = (root.Position - Camera.CFrame.Position).Magnitude
            local rPos, onScreen = Camera:WorldToViewportPoint(root.Position)
            
            -- Chams
            local highlight = char:FindFirstChild("EliteCham")
            if ESP.Chams then
                if not highlight then highlight = Instance.new("Highlight", char); highlight.Name = "EliteCham" end
                highlight.FillColor = Color3.fromRGB(0, 255, 120); highlight.Enabled = true
            elseif highlight then highlight:Destroy() end

            -- Visuals
            if onScreen then
                local hPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                local lPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))
                local height = math.abs(hPos.Y - lPos.Y); local width = height / 1.8

                d.Box.Visible = ESP.Boxes; d.Box.Size = Vector2.new(width, height); d.Box.Position = Vector2.new(rPos.X - width/2, hPos.Y)
                d.Name.Visible = ESP.Names; d.Name.Position = Vector2.new(rPos.X, hPos.Y - 15); d.Name.Text = p.Name .. " [" .. math.floor(distFromPlayer) .. "]"

                if ESP.Health then
                    local hp = hum.Health / hum.MaxHealth
                    d.HealthOutline.Visible = true; d.HealthOutline.Position = Vector2.new(rPos.X - width/2 - 6, hPos.Y); d.HealthOutline.Size = Vector2.new(4, height); d.HealthOutline.Color = Color3.new(0, 0, 0)
                    d.HealthBar.Visible = true; d.HealthBar.Position = Vector2.new(rPos.X - width/2 - 5, hPos.Y + (height * (1-hp))); d.HealthBar.Size = Vector2.new(2, height * hp); d.HealthBar.Color = Color3.fromHSV(hp * 0.3, 1, 1)
                else d.HealthBar.Visible = false; d.HealthOutline.Visible = false end

                if ESP.Skeleton then
                    for i, bones in pairs(SkeletonParts) do
                        local b1, b2 = char:FindFirstChild(bones[1]), char:FindFirstChild(bones[2])
                        if b1 and b2 then
                            local v1, o1 = Camera:WorldToViewportPoint(b1.Position)
                            local v2, o2 = Camera:WorldToViewportPoint(b2.Position)
                            d.Skeleton[i].Visible = o1 and o2; d.Skeleton[i].From = Vector2.new(v1.X, v1.Y); d.Skeleton[i].To = Vector2.new(v2.X, v2.Y)
                        else d.Skeleton[i].Visible = false end
                    end
                else for _, l in pairs(d.Skeleton) do l.Visible = false end end

                if ESP.LockOn and distFromPlayer <= ESP.MaxDistance then
                    local screenDist = (Vector2.new(rPos.X, rPos.Y) - screenCenter).Magnitude
                    if screenDist < closestDist and IsVisible(head) then closestDist = screenDist; targetPart = head end
                end
            else
                d.Box.Visible = false; d.Name.Visible = false; d.HealthBar.Visible = false; d.HealthOutline.Visible = false
                for _, l in pairs(d.Skeleton) do l.Visible = false end
            end
        else
            d.Box.Visible = false; d.Name.Visible = false; d.HealthBar.Visible = false; d.HealthOutline.Visible = false
            for _, l in pairs(d.Skeleton) do l.Visible = false end
        end
    end

    -- AIM EXECUTION
    if targetPart and ESP.LockOn then
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if myRoot then
            local alpha = math.clamp((ESP.Smoothness / 10) * (dt * 60), 0.01, 1)
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, targetPart.Position), alpha)
            local goalPos = Vector3.new(targetPart.Position.X, myRoot.Position.Y, targetPart.Position.Z)
            myRoot.CFrame = myRoot.CFrame:Lerp(CFrame.lookAt(myRoot.Position, goalPos), alpha)
        end
    end
end)

