--// UI COMPONENTS
local function CreateToggle(name, key, parent)
    local holder = Instance.new("Frame", parent)
    holder.Size = UDim2.new(1, 0, 0, 35)
    holder.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
    Instance.new("UICorner", holder)

    local btn = Instance.new("TextButton", holder)
    btn.Size = UDim2.new(0, 45, 0, 20)
    btn.Position = UDim2.new(1, -50, 0.5, -10)
    btn.Text = ESP[key] and "ON" or "OFF"
    btn.BackgroundColor3 = ESP[key] and Color3.fromRGB(0, 180, 120) or Color3.fromRGB(50, 50, 55)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 10
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)

    local lbl = Instance.new("TextLabel", holder)
    lbl.Text = "  " .. name
    lbl.Size = UDim2.new(0.7, 0, 1, 0)
    lbl.TextColor3 = Color3.new(1, 1, 1)
    lbl.BackgroundTransparency = 1
    lbl.TextXAlignment = "Left"
    lbl.Font = Enum.Font.Gotham

    btn.MouseButton1Click:Connect(function()
        ESP[key] = not ESP[key]
        btn.Text = ESP[key] and "ON" or "OFF"
        btn.BackgroundColor3 = ESP[key] and Color3.fromRGB(0, 180, 120) or Color3.fromRGB(50, 50, 55)
    end)
end

local function CreateSlider(name, min, max, key, parent)
    local holder = Instance.new("Frame", parent)
    holder.Size = UDim2.new(1, 0, 0, 50)
    holder.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
    Instance.new("UICorner", holder)

    local label = Instance.new("TextLabel", holder)
    label.Text = "  " .. name .. ": " .. ESP[key]
    label.Size = UDim2.new(1, 0, 0, 25)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = "Left"
    label.TextSize = 12

    local sliderBg = Instance.new("Frame", holder)
    sliderBg.Size = UDim2.new(0.9, 0, 0, 4)
    sliderBg.Position = UDim2.new(0.05, 0, 0.7, 0)
    sliderBg.BackgroundColor3 = Color3.fromRGB(50, 50, 55)

    local sliderFill = Instance.new("Frame", sliderBg)
    sliderFill.Size = UDim2.new((ESP[key] - min) / (max - min), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(0, 180, 120)

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local connection
            connection = RunService.RenderStepped:Connect(function()
                local mousePos = UIS:GetMouseLocation().X
                local relativeX = math.clamp((mousePos - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
                ESP[key] = math.floor(min + (relativeX * (max - min)))
                label.Text = "  " .. name .. ": " .. ESP[key]
                sliderFill.Size = UDim2.new(relativeX, 0, 1, 0)
                if not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                    connection:Disconnect()
                end
            end)
        end
    end)
end

