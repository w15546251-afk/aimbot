--// LOGIC
local fovCircle = Drawing.new("Circle")
fovCircle.Thickness = 1; fovCircle.Color = Color3.new(1, 1, 1); fovCircle.Transparency = 0.5

local SkeletonParts = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},{"UpperTorso","LeftUpperArm"},
    {"LeftUpperArm","LeftLowerArm"},{"LeftUpperArm","LeftHand"},{"UpperTorso","RightUpperArm"},
    {"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},{"LowerTorso","LeftUpperLeg"},
    {"LeftUpperLeg","LeftLowerLeg"},{"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"}
}

local Drawings = {}
local function GetDrawings(p)
    if Drawings[p] then return Drawings[p] end
    local d = {
        Box = Drawing.new("Square"), Name = Drawing.new("Text"),
        HealthOutline = Drawing.new("Square"), HealthBar = Drawing.new("Square"),
        Skeleton = {}
    }
    d.Box.Thickness = 1; d.Box.Color = Color3.new(1, 1, 1)
    d.Name.Center = true; d.Name.Outline = true; d.Name.Size = 13; d.Name.Color = Color3.new(1, 1, 1)
    d.HealthBar.Filled = true; d.HealthOutline.Filled = true
    for i=1,#SkeletonParts do
        local l = Drawing.new("Line"); l.Thickness = 1; l.Color = Color3.new(1, 1, 1); table.insert(d.Skeleton, l)
    end
    Drawings[p] = d
    return d
end

local function IsVisible(targetPart)
    if not ESP.WallCheck then return true end
    local cast = workspace:Raycast(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position), RaycastParams.new())
    return not cast or cast.Instance:IsDescendantOf(targetPart.Parent)
end

RunService.RenderStepped:Connect(function(dt)
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    fovCircle.Visible = ESP.LockOn; fovCircle.Radius = ESP.FOV; fovCircle.Position = screenCenter

    local targetHead = nil
    local closestDist = ESP.FOV

    for _, p in pairs(Players:GetPlayers()) do
        local d = GetDrawings(p)
        
        -- Reset every frame
        d.Box.Visible = false; d.Name.Visible = false; d.HealthBar.Visible = false; d.HealthOutline.Visible = false
        for _, l in pairs(d.Skeleton) do l.Visible = false end

        if p == LocalPlayer then continue end

        local char = p.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local head = char and char:FindFirstChild("Head")

        if char and hum and hum.Health > 0 and root and head then
            local dist = (root.Position - Camera.CFrame.Position).Magnitude
            
            local highlight = char:FindFirstChild("EliteCham")
            if ESP.Chams then
                if not highlight then
                    highlight = Instance.new("Highlight", char)
                    highlight.Name = "EliteCham"
                    highlight.FillColor = Color3.fromRGB(0, 255, 120)
                end
            elseif highlight then highlight:Destroy() end

            local rPos, onScreen = Camera:WorldToViewportPoint(root.Position)
            if onScreen then
                pcall(function()
                    local hPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                    local lPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))
                    local height = math.abs(hPos.Y - lPos.Y)
                    local width = height / 1.8

                    if ESP.Boxes then
                        d.Box.Visible = true; d.Box.Size = Vector2.new(width, height); d.Box.Position = Vector2.new(rPos.X - width/2, hPos.Y)
                    end
                    if ESP.Names then
                        d.Name.Visible = true; d.Name.Position = Vector2.new(rPos.X, hPos.Y - 15); d.Name.Text = p.Name
                    end
                    if ESP.Health then
                        local hp = hum.Health / hum.MaxHealth
                        d.HealthOutline.Visible = true; d.HealthOutline.Position = Vector2.new(rPos.X - width/2 - 6, hPos.Y); d.HealthOutline.Size = Vector2.new(4, height); d.HealthOutline.Color = Color3.new(0,0,0)
                        d.HealthBar.Visible = true; d.HealthBar.Position = Vector2.new(rPos.X - width/2 - 5, hPos.Y + (height * (1-hp))); d.HealthBar.Size = Vector2.new(2, height * hp); d.HealthBar.Color = Color3.fromHSV(hp * 0.3, 1, 1)
                    end
                    if ESP.Skeleton then
                        for i, bones in pairs(SkeletonParts) do
                            local b1, b2 = char:FindFirstChild(bones[1]), char:FindFirstChild(bones[2])
                            if b1 and b2 then
                                local v1, o1 = Camera:WorldToViewportPoint(b1.Position)
                                local v2, o2 = Camera:WorldToViewportPoint(b2.Position)
                                if o1 and o2 then d.Skeleton[i].Visible = true; d.Skeleton[i].From = Vector2.new(v1.X,v1.Y); d.Skeleton[i].To = Vector2.new(v2.X,v2.Y) end
                            end
                        end
                    end
                    
                    if ESP.LockOn and dist <= ESP.MaxDistance then
                        local sDist = (Vector2.new(rPos.X, rPos.Y) - screenCenter).Magnitude
                        if sDist < closestDist and IsVisible(head) then closestDist = sDist; targetHead = head end
                    end
                end)
            end
        else
            local h = char and char:FindFirstChild("EliteCham")
            if h then h:Destroy() end
        end
    end

    if targetHead and ESP.LockOn then
        local alpha = math.clamp((ESP.Smoothness / 10) * (dt * 60), 0.01, 1)
        Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, targetHead.Position), alpha)
    end
end)

--// FIXED REMOVAL LOGIC
local function Cleanup(p)
    if Drawings[p] then
        for _, obj in pairs(Drawings[p]) do
            if typeof(obj) == "table" then -- For Skeleton lines
                for _, line in pairs(obj) do line:Remove() end
            elseif typeof(obj) == "userdata" then -- For Squares/Text
                obj:Remove()
            end
        end
        Drawings[p] = nil
    end
end

Players.PlayerRemoving:Connect(Cleanup)

UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == MenuKey then
        main.Visible = not main.Visible
        if not main.Visible then SaveSettings() end
    elseif input.KeyCode == LockBind or input.UserInputType == LockBind then
        ESP.LockOn = not ESP.LockOn
        if lockToggleBtn then
            lockToggleBtn.Text = ESP.LockOn and "ON" or "OFF"
            lockToggleBtn.BackgroundColor3 = ESP.LockOn and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(45, 45, 50)
        end
    end
end)

task.spawn(function() while task.wait(10) do SaveSettings() end end)
