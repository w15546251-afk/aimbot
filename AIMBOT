--// LOGIC ENGINE
local FOV_Ring = Drawing.new("Circle"); FOV_Ring.Thickness = 1; FOV_Ring.Color = Color3.new(1,1,1); FOV_Ring.Transparency = 0.5
local PlayerDrawings = {}
local Bones = {{"Head","UpperTorso"},{"UpperTorso","LowerTorso"},{"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"}}

local function GetDraws(p)
    if PlayerDrawings[p] then return PlayerDrawings[p] end
    local d = {Box = Drawing.new("Square"), Name = Drawing.new("Text"), HealthBar = Drawing.new("Square"), HealthOutline = Drawing.new("Square"), Skeleton = {}}
    d.Box.Thickness = 1; d.Box.Color = Color3.new(1,1,1); d.Name.Size = 13; d.Name.Center = true; d.Name.Outline = true; d.Name.Color = Color3.new(1,1,1); d.HealthBar.Filled = true; d.HealthOutline.Filled = true
    for i=1, #Bones do local l = Drawing.new("Line"); l.Thickness = 1; l.Color = Color3.new(1,1,1); table.insert(d.Skeleton, l) end
    PlayerDrawings[p] = d; return d
end

local function IsVisible(part)
    if not Settings.WallCheck then return true end
    local cast = Cam:GetPartsObscuringTarget({part.Position}, {LP.Character, part.Parent})
    return #cast == 0
end

RunService.RenderStepped:Connect(function(dt)
    local center = Vector2.new(Cam.ViewportSize.X/2, Cam.ViewportSize.Y/2)
    FOV_Ring.Visible = Settings.LockOn; FOV_Ring.Position = center; FOV_Ring.Radius = Settings.FOV
    
    local target = nil; local minDistance = Settings.FOV

    for _, p in pairs(Players:GetPlayers()) do
        if p == LP then continue end
        local d = GetDraws(p); d.Box.Visible = false; d.Name.Visible = false; d.HealthBar.Visible = false; d.HealthOutline.Visible = false
        for _, l in pairs(d.Skeleton) do l.Visible = false end

        if (Settings.TeamCheck and p.Team == LP.Team) or (Settings.FriendCheck and LP:IsFriendsWith(p.UserId)) then 
            if p.Character and p.Character:FindFirstChild("EliteCham") then p.Character.EliteCham:Destroy() end
            continue 
        end

        local char = p.Character
        if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
            local root = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            if root and head then
                local pos, visible = Cam:WorldToViewportPoint(root.Position)
                local mag = (root.Position - Cam.CFrame.Position).Magnitude
                
                if visible and mag < Settings.MaxDistance then
                    -- ESP Rendering
                    local headP = Cam:WorldToViewportPoint(head.Position + Vector3.new(0, 0.6, 0))
                    local btmP = Cam:WorldToViewportPoint(root.Position - Vector3.new(0, 3.2, 0))
                    local h = math.abs(headP.Y - btmP.Y); local w = h / 1.6

                    if Settings.Boxes then d.Box.Visible = true; d.Box.Size = Vector2.new(w, h); d.Box.Position = Vector2.new(pos.X - w/2, headP.Y) end
                    if Settings.Names then d.Name.Visible = true; d.Name.Position = Vector2.new(pos.X, headP.Y - 15); d.Name.Text = p.Name end
                    if Settings.Health then
                        local ratio = char.Humanoid.Health / char.Humanoid.MaxHealth
                        d.HealthOutline.Visible = true; d.HealthOutline.Position = Vector2.new(pos.X - w/2 - 6, headP.Y); d.HealthOutline.Size = Vector2.new(4, h)
                        d.HealthBar.Visible = true; d.HealthBar.Position = Vector2.new(pos.X - w/2 - 5, headP.Y + (h * (1-ratio))); d.HealthBar.Size = Vector2.new(2, h * ratio); d.HealthBar.Color = Color3.fromHSV(ratio * 0.3, 1, 1)
                    end
                    if Settings.Skeleton then
                        for i, b in pairs(Bones) do
                            local p1, p2 = char:FindFirstChild(b[1]), char:FindFirstChild(b[2])
                            if p1 and p2 and d.Skeleton[i] then
                                local v1, os1 = Cam:WorldToViewportPoint(p1.Position); local v2, os2 = Cam:WorldToViewportPoint(p2.Position)
                                if os1 and os2 then d.Skeleton[i].Visible = true; d.Skeleton[i].From = Vector2.new(v1.X, v1.Y); d.Skeleton[i].To = Vector2.new(v2.X, v2.Y) end
                            end
                        end
                    end
                    if Settings.Chams then
                        local hi = char:FindFirstChild("EliteCham") or Instance.new("Highlight", char); hi.Name = "EliteCham"; hi.FillColor = Color3.fromRGB(0, 255, 120)
                    elseif char:FindFirstChild("EliteCham") then char.EliteCham:Destroy() end

                    -- Aim Logic (Head Only)
                    local sDist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if sDist < minDistance and IsVisible(head) then minDistance = sDist; target = head end
                end
            end
        end
    end
    
    if target and Settings.LockOn then
        local targetCF = CFrame.lookAt(Cam.CFrame.Position, target.Position)
        local alpha = math.clamp((Settings.Smoothness / 10) * (dt * 60), 0.05, 1)
        Cam.CFrame = Cam.CFrame:Lerp(targetCF, alpha)
    end
end)

--// INPUTS
UIS.InputBegan:Connect(function(i, g) 
    if g then return end
    if i.KeyCode.Name == Settings.MenuKey then main.Visible = not main.Visible 
    elseif i.KeyCode.Name == Settings.LockBind or i.UserInputType.Name == Settings.LockBind then 
        Settings.LockOn = not Settings.LockOn
        if lockToggleBtn then
            lockToggleBtn.Text = Settings.LockOn and "ON" or "OFF"
            lockToggleBtn.BackgroundColor3 = Settings.LockOn and Color3.fromRGB(0, 255, 120) or Color3.fromRGB(50, 50, 50)
        end
    end 
end)

Players.PlayerRemoving:Connect(function(p)
    if PlayerDrawings[p] then
        for _, obj in pairs(PlayerDrawings[p]) do if typeof(obj) == "table" then for _, l in pairs(obj) do l:Remove() end else obj:Remove() end end
        PlayerDrawings[p] = nil
    end
end)
