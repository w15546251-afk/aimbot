--// DRAWING SYSTEM
local fovCircle = Drawing.new("Circle")
fovCircle.Thickness = 1
fovCircle.Color = Color3.new(1, 1, 1)
fovCircle.Transparency = 0.5

local Drawings = {}
local SkeletonParts = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},{"UpperTorso","LeftUpperArm"},
    {"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},{"UpperTorso","RightUpperArm"},
    {"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},{"LowerTorso","LeftUpperLeg"},
    {"LeftUpperLeg","LeftLowerLeg"},{"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"}
}

local function CreateDrawings(player)
    local d = {
        Box = Drawing.new("Square"),
        HealthOutline = Drawing.new("Square"),
        HealthBar = Drawing.new("Square"),
        Name = Drawing.new("Text"),
        Skeleton = {}
    }
    d.Box.Thickness = 1
    d.Box.Color = Color3.new(1, 1, 1) 
    d.Name.Center = true
    d.Name.Outline = true
    d.Name.Size = 13
    d.Name.Color = Color3.new(1, 1, 1)
    d.HealthBar.Filled = true
    d.HealthOutline.Filled = true
    d.HealthOutline.Color = Color3.new(0,0,0)
    for i=1,#SkeletonParts do
        local l = Drawing.new("Line")
        l.Thickness = 1
        l.Color = Color3.new(1,1,1)
        table.insert(d.Skeleton, l)
    end
    Drawings[player] = d
end

local function ForceHide(d)
    if not d then return end
    d.Box.Visible = false
    d.Name.Visible = false
    d.HealthOutline.Visible = false
    d.HealthBar.Visible = false
    for _, l in pairs(d.Skeleton) do l.Visible = false end
end

--// MAIN LOOP
RunService.RenderStepped:Connect(function()
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    fovCircle.Visible = ESP.LockOn
    fovCircle.Radius = ESP.FOV
    fovCircle.Position = screenCenter

    local targetHead = nil
    local closestDist = ESP.FOV

    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if not Drawings[p] then CreateDrawings(p) end
        
        local d = Drawings[p]
        local char = p.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        if char and hum and root and hum.Health > 0 then
            local rPos, onScreen = Camera:WorldToViewportPoint(root.Position)
            
            if onScreen then
                local head = char:FindFirstChild("Head") or root
                local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                local legPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
                local h = math.abs(headPos.Y - legPos.Y)
                local w = h / 2
                
                d.Box.Visible = ESP.Boxes
                d.Box.Size = Vector2.new(w, h)
                d.Box.Position = Vector2.new(rPos.X - w/2, headPos.Y)
                
                d.Name.Visible = ESP.Names
                d.Name.Position = Vector2.new(rPos.X, headPos.Y - 15)
                d.Name.Text = p.Name
                
                if ESP.Health then
                    local hp = hum.Health / hum.MaxHealth
                    d.HealthOutline.Visible = true
                    d.HealthOutline.Size = Vector2.new(4, h)
                    d.HealthOutline.Position = Vector2.new(rPos.X - w/2 - 6, headPos.Y)
                    d.HealthBar.Visible = true
                    d.HealthBar.Size = Vector2.new(2, h * hp)
                    d.HealthBar.Position = Vector2.new(rPos.X - w/2 - 5, headPos.Y + (h * (1-hp)))
                    d.HealthBar.Color = Color3.fromHSV(hp * 0.3, 1, 1)
                else
                    d.HealthBar.Visible = false
                    d.HealthOutline.Visible = false
                end

                if ESP.Skeleton then
                    for i, bones in pairs(SkeletonParts) do
                        local p1, p2 = char:FindFirstChild(bones[1]), char:FindFirstChild(bones[2])
                        if p1 and p2 then
                            local v1, o1 = Camera:WorldToViewportPoint(p1.Position)
                            local v2, o2 = Camera:WorldToViewportPoint(p2.Position)
                            d.Skeleton[i].Visible = o1 and o2
                            d.Skeleton[i].From = Vector2.new(v1.X, v1.Y)
                            d.Skeleton[i].To = Vector2.new(v2.X, v2.Y)
                        else d.Skeleton[i].Visible = false end
                    end
                else
                    for _,l in pairs(d.Skeleton) do l.Visible = false end
                end

                -- Chams
                local highlight = char:FindFirstChild("ESPHighlight")
                if ESP.Chams then
                    if not highlight then
                        highlight = Instance.new("Highlight", char)
                        highlight.Name = "ESPHighlight"
                    end
                    highlight.Enabled = true
                    highlight.FillColor = HIGHLIGHT_COLOR
                elseif highlight then
                    highlight.Enabled = false
                end

                -- Target Detection
                if ESP.LockOn then
                    local dist = (Vector2.new(rPos.X, rPos.Y) - screenCenter).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        targetHead = head
                    end
                end
            else
                ForceHide(d)
            end
        else
            ForceHide(d)
        end
    end
    
    -- HARD LOCK LOGIC
    if targetHead and ESP.LockOn then
        -- Map 1-10 to 0.05-1.0 lerp factor
        -- At 10, it is 1.0 (Instant, unshakeable stick)
        local intensity = (ESP.Smoothness - 1) / 9
        local lerpFactor = 0.05 + (intensity * 0.95)
        
        Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, targetHead.Position), lerpFactor)
    end
end)

-- Cleanup on Player Leave
Players.PlayerRemoving:Connect(function(p)
    if Drawings[p] then
        for _, v in pairs(Drawings[p]) do
            if typeof(v) == "userdata" then v:Remove() 
            elseif type(v) == "table" then for _, l in pairs(v) do l:Remove() end end
        end
        Drawings[p] = nil
    end
end)

-- Menu Input
UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if listening then
        MenuKey = input.KeyCode
        bindBtn.Text = "Menu Key: " .. MenuKey.Name
        listening = false
    elseif input.KeyCode == MenuKey then
        main.Visible = not main.Visible
    end
end)
